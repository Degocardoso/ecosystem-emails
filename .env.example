# ===========================================================================
#  ECOSSISTEMA DE E-MAILS FECAP — Exemplo de configuração de ambiente
#  -------------------------------------------------------------------------
#  1. Copie este arquivo para ".env"  ->  cp .env.example .env
#  2. Preencha com os valores REAIS do seu ambiente.
#  3. NUNCA versione o arquivo ".env" (já está protegido pelo .gitignore).
# ===========================================================================

# --- Ambiente da aplicação ---
APP_ENV=production              # production | development
APP_DEBUG=false                # true APENAS em desenvolvimento (nunca em produção)
APP_URL=http://localhost/ecosystem-emails

# --- Banco de dados (MySQL / phpMyAdmin) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ecosystem_emails
DB_USER=ecosystem_app
DB_PASS=troque_esta_senha
DB_CHARSET=utf8mb4

# --- Sessão ---
SESSION_NAME=ECOSSISTEMA_SESSID
SESSION_LIFETIME=120           # tempo de vida da sessão em minutos

# --- Segurança de login (proteção contra força bruta) ---
LOGIN_MAX_ATTEMPTS=5           # tentativas falhas antes do bloqueio temporário
LOGIN_LOCKOUT_MINUTES=15       # duração do bloqueio temporário (minutos)

# --- Gerador de E-mails: URL do fluxo do Power Automate ---
# Cole aqui a URL do gatilho HTTP do Power Automate (contém assinatura sensível!).
POWER_AUTOMATE_URL=

# --- Microsoft Dynamics 365 (módulo de relatórios) ---
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
RESOURCE=https://suaorg.crm.dynamics.com

# --- Rate limit do módulo de relatórios ---
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_PERIOD_MINUTES=60

# --- Cache (opcional). Deixe REDIS_HOST vazio para usar cache em arquivo ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Nível de log ---
LOG_LEVEL=error                # debug | info | notice | warning | error | critical
